                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Qty, StringFormat={}{0:F2}}" Width="60"/>
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="50"/>
                                    <DataGridTextColumn Header="Rate" Binding="{Binding Rate}" Width="70"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N0}}" Width="90" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
