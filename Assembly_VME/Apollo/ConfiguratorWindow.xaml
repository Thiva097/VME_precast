            <TabItem Header="Update BBS" Margin="0,6,0,0">
                <DockPanel Margin="10">
                    <!-- Footer Area -->
                    <Border DockPanel.Dock="Bottom" Padding="15,10" Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="0,1,0,0">
                        <Button x:Name="btnExportBBS" Style="{StaticResource ActionButtonStyle}" Click="btnExportBBS_Click" IsEnabled="False" Height="40">
                            <TextBlock Text="Export BBS to Excel" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Button>
                    </Border>

                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="REINFORCEMENT SCHEDULE" Style="{StaticResource SectionTitle}"/>
                        <Button x:Name="btnUpdateBBS" Style="{StaticResource ActionButtonStyle}" Click="btnUpdateBBS_Click" IsEnabled="False" Height="40">
                            <TextBlock Text="Generate Full Tank BBS Report" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                    
                    <Border x:Name="sectionBBS" Visibility="Collapsed">
                        <DockPanel>
                            <Border DockPanel.Dock="Bottom" Background="#f8f9fa" Margin="0,10,0,0" Padding="15,10">
                                <DockPanel>
                                    <TextBlock Text="Total Reinforcement Weight" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}"/>
                                    <TextBlock x:Name="txtTotalRebarWeight" Text="0.00 kg" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Right"/>
                                </DockPanel>
                            </Border>
                            
                            <DataGrid x:Name="dgBBS" AutoGenerateColumns="False" CanUserAddRows="False" 
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="White" BorderThickness="0" RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mark" Binding="{Binding Mark}" Width="40"/>
                                    <DataGridTextColumn Header="Dia" Binding="{Binding Diameter}" Width="35"/>
                                    <DataGridTextColumn Header="Shape" Binding="{Binding Shape}" Width="60"/>
                                    <DataGridTextColumn Header="A" Binding="{Binding A}" Width="40"/>
                                    <DataGridTextColumn Header="B" Binding="{Binding B}" Width="40"/>
                                    <DataGridTextColumn Header="C" Binding="{Binding C}" Width="40"/>
                                    <DataGridTextColumn Header="D" Binding="{Binding D}" Width="40"/>
                                    <DataGridTextColumn Header="E" Binding="{Binding E}" Width="40"/>
                                    <DataGridTextColumn Header="Bar Len" Binding="{Binding BarLength, StringFormat={}{0:F0}}" Width="60"/>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="40"/>
                                    <DataGridTextColumn Header="Weight" Binding="{Binding Weight, StringFormat={}{0:F2}}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </TabItem>

            </TabControl>
        </DockPanel>
    </Border>
</Window>