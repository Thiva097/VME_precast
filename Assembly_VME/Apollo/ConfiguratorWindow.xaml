<Window x:Class="VME_Apollo.ConfiguratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precast Configurator" Height="750" Width="550"
        WindowStartupLocation="CenterScreen" Background="Transparent"
        AllowsTransparency="True" WindowStyle="None"
        FontFamily="Segoe UI" UseLayoutRounding="True">
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryBlue"    Color="#2d4a7a"/>
        <SolidColorBrush x:Key="SelectedBlueBg" Color="#e8f0fe"/>
        <SolidColorBrush x:Key="BorderGray"     Color="#dddddd"/>
        <SolidColorBrush x:Key="TextGray"       Color="#666666"/>
        <SolidColorBrush x:Key="DoneGreenBg"    Color="#e6f4ea"/>
        <SolidColorBrush x:Key="DoneGreenText"  Color="#137333"/>
        <SolidColorBrush x:Key="TitleBarBg"     Color="#f8f9fa"/>

        <!-- Tab Item Style -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Margin="0,0,5,0" Padding="15,10" Background="#eeeeee" CornerRadius="5,5,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BorderGray}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,0"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Button Style -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#eeeeee"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section Border Style -->
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background"        Value="White"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="CornerRadius"      Value="3"/>
            <Setter Property="Padding"           Value="12"/>
            <Setter Property="Margin"            Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Foreground"    Value="#555555"/>
            <Setter Property="Margin"        Value="0,0,0,10"/>
        </Style>

        <Style x:Key="GridButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background"          Value="White"/>
            <Setter Property="BorderBrush"         Value="#cccccc"/>
            <Setter Property="BorderThickness"     Value="1.5"/>
            <Setter Property="Padding"             Value="10"/>
            <Setter Property="Margin"              Value="4"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background"  Value="{StaticResource SelectedBlueBg}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background"              Value="White"/>
            <Setter Property="BorderBrush"             Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness"         Value="1.5"/>
            <Setter Property="Padding"                 Value="12,8"/>
            <Setter Property="Margin"                  Value="0,0,0,6"/>
            <Setter Property="FontSize"                Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="5,0,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Background="White" CornerRadius="8">
        <DockPanel>
            <!-- Custom Title Bar -->
            <Border DockPanel.Dock="Top" Background="{StaticResource TitleBarBg}" Height="40" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                        <Image Source="pack://application:,,,/Assembly_VME;component/Apollo/Assets/ODF.png" Height="24" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </StackPanel>

                    <!-- Centered Title and Version -->
                    <TextBlock Text="Precast Configurator V 1.0.0.0" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource PrimaryBlue}" 
                               FontSize="12"/>
                    
                   <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <!-- <Button Style="{StaticResource WindowControlButtonStyle}" Click="SopButton_Click" ToolTip="Standard Operating Procedure">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SOP" VerticalAlignment="Center" FontSize="10"/>
                            </StackPanel>
                        </Button>-->
                        <Button Style="{StaticResource WindowControlButtonStyle}" Content="?" Click="HelpButton_Click" ToolTip="Help"/>
                        <Button Style="{StaticResource WindowControlButtonStyle}" Content="—" Click="MinimizeButton_Click"/>
                        <Button Style="{StaticResource WindowControlButtonStyle}" Content="☐" Click="MaximizeButton_Click"/>
                        <Button Style="{StaticResource CloseButtonStyle}" Content="✕" Click="CloseButton_Click"/>
                        </StackPanel>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource PrimaryBlue}" Padding="12,4" CornerRadius="0,0,8,8">
                <TextBlock Name="statusText" Text="Ready" FontSize="11" Foreground="White" Opacity="0.85"/>
            </Border>

            <!-- Main Navigation Tabs -->
            <TabControl BorderThickness="0,1,0,0" Margin="5">
                <!-- PRECAST TAB -->
                <TabItem Header="Precast" Margin="0,6,0,0">
                    <DockPanel>
                        <!-- Footer Button Area -->
                        <Border DockPanel.Dock="Bottom" Padding="15,10" Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="0,1,0,0">
                            <UniformGrid Columns="2">
                                <Button x:Name="btnGenerate" Style="{StaticResource ActionButtonStyle}" Click="btnGenerate_Click" Height="50" Margin="0,0,5,0">
                                    <TextBlock Text="Generate Model" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                </Button>
                                <Button x:Name="btnUpdate" Style="{StaticResource ActionButtonStyle}" Click="btnUpdate_Click" Height="50" Margin="5,0,0,0" IsEnabled="False">
                                    <TextBlock Text="Update Model" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                </Button>
                            </UniformGrid>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15">
                            <TextBlock Text="ELEMENT TYPE" Style="{StaticResource SectionTitle}"/>
                            <UniformGrid Columns="3" Margin="0,0,0,20">
                                <ToggleButton x:Name="rbWaterTank" Style="{StaticResource GridButtonStyle}" IsChecked="True" Click="ElementType_Click" Padding="5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Source="pack://application:,,,/Assembly_VME;component/Apollo/Assets/tank.png" Height="32" Margin="0,0,0,5" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Water Tank" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="rbDrain" Style="{StaticResource GridButtonStyle}" Click="ElementType_Click" Padding="5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Source="pack://application:,,,/Assembly_VME;component/Apollo/Assets/drain.png" Height="32" Margin="0,0,0,5" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Drain" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="rbWall" Style="{StaticResource GridButtonStyle}" Click="ElementType_Click" Padding="5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Source="pack://application:,,,/Assembly_VME;component/Apollo/Assets/wall.png" Height="32" Margin="0,0,0,5" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Wall" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </ToggleButton>
                            </UniformGrid>

                            <!-- Specification Section -->
                            <Border x:Name="sectionSpecification" Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock x:Name="typeTag" Text="TYPE OF TANK" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource PrimaryBlue}"/>
                                    
                                    <UniformGrid x:Name="gridTankTypes" Columns="3" Margin="0,0,0,10">
                                        <ToggleButton Name="btnMonolithic" Style="{StaticResource GridButtonStyle}" IsChecked="True" Click="SpecType_Click" Content="Monolithic Tank" Height="30" Width="129"/>
                                        <ToggleButton Name="btnPT" Style="{StaticResource GridButtonStyle}" Click="SpecType_Click" Content="PT Tank" Width="133"/>
                                        <ToggleButton Name="btnCustomPT" Style="{StaticResource GridButtonStyle}" Click="SpecType_Click" Content="Custom PT Tank" Width="130"/>
                                    </UniformGrid>

                                    <!-- Standard Panel -->
                                    <StackPanel Name="panelStandard">
                                        <!-- Monolithic Capacities -->
                                        <StackPanel Name="panelMonolithicCap" Visibility="Visible">
                                            <TextBlock Text="TANK CAPACITY" Style="{StaticResource SectionTitle}"/>
                                            <UniformGrid Columns="3" Margin="0,0,0,10">
                                                <ToggleButton Name="cap6" Content="6 KL" Style="{StaticResource GridButtonStyle}" IsChecked="True" Click="Capacity_Click" Width="130" Height="25"/>
                                                <ToggleButton Name="cap105" Content="10.5 KL" Style="{StaticResource GridButtonStyle}" Click="Capacity_Click" Width="129"/>
                                                <ToggleButton Name="cap125" Content="12.5 KL" Style="{StaticResource GridButtonStyle}" Click="Capacity_Click" Width="128"/>
                                            </UniformGrid>
                                        </StackPanel>

                                        <!-- PT Tank Capacities -->
                                        <StackPanel Name="panelPTCap" Visibility="Collapsed">
                                            <TextBlock Text="TANK CAPACITY" Style="{StaticResource SectionTitle}"/>
                                            <UniformGrid Columns="4" Margin="0,0,0,10">
                                                <ToggleButton Name="cap25" Content="25 KL" Style="{StaticResource GridButtonStyle}" IsChecked="True" Click="Capacity_Click"/>
                                                <ToggleButton Name="cap30" Content="30 KL" Style="{StaticResource GridButtonStyle}" Click="Capacity_Click"/>
                                                <ToggleButton Name="cap45" Content="45 KL" Style="{StaticResource GridButtonStyle}" Click="Capacity_Click"/>
                                                <ToggleButton Name="cap50" Content="50 KL" Style="{StaticResource GridButtonStyle}" Click="Capacity_Click"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Non-Standard / Dimension Display Panel -->
                                    <!-- Not Implemented Message -->
                                    <Border x:Name="panelNotImplemented" Visibility="Collapsed" Padding="30" Background="#f8f9fa" CornerRadius="5">
                                        <StackPanel VerticalAlignment="Center">
                                            <Image Source="pack://application:,,,/Assembly_VME;component/Apollo/Assets/tank.png" Height="64" Opacity="0.1" Margin="0,0,0,15"/>
                                            <TextBlock Text="Feature Coming Soon" FontWeight="Bold" FontSize="16" Foreground="#BDC3C7" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Configuration for Drain and Wall elements is currently under development." FontSize="11" Foreground="#BDC3C7" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Non-Standard / Dimension Display Panel -->
                                    <StackPanel Name="panelNonStandard" Visibility="Visible">
                                        <TextBlock Text="TANK DIMENSIONS (in meters)" Style="{StaticResource SectionTitle}"/>
                                        <UniformGrid Columns="3">
                                            <StackPanel Margin="0,0,5,8">
                                                <TextBlock Text="Length" FontSize="10" Foreground="#7F8C8D"/>
                                                <TextBox Name="txtLength" Text="2.0" Padding="5" IsReadOnly="True" Background="#F9F9F9" TextChanged="Dimension_TextChanged"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,5,8">
                                                <TextBlock Text="Width" FontSize="10" Foreground="#7F8C8D"/>
                                                <TextBox Name="txtWidth" Text="1.5" Padding="5" IsReadOnly="True" Background="#F9F9F9" TextChanged="Dimension_TextChanged"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="Height" FontSize="10" Foreground="#7F8C8D"/>
                                                <TextBox Name="txtHeight" Text="2.0" Padding="5" IsReadOnly="True" Background="#F9F9F9" TextChanged="Dimension_TextChanged"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,5,0">
                                                <TextBlock Text="Wall Thick." FontSize="10" Foreground="#7F8C8D"/>
                                                <TextBox x:Name="txtWallThickness" Text="0.085" Padding="5" IsReadOnly="True" Background="#F9F9F9"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,5,0">
                                                <TextBlock Text="Base Slab" FontSize="10" Foreground="#7F8C8D"/>
                                                <TextBox x:Name="txtBaseSlabThickness" Text="0.125" Padding="5" IsReadOnly="True" Background="#F9F9F9"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Cover Slab" FontSize="10" Foreground="#7F8C8D"/>
                                                <TextBox x:Name="txtCoverSlabThickness" Text="0.15" Padding="5" IsReadOnly="True" Background="#F9F9F9"/>
                                            </StackPanel>
                                        </UniformGrid>
                                        
                                        <!-- Capacity Display -->
                                        <Border x:Name="panelCapacity" Background="#e6f4ea" Padding="15,10" Margin="0,10,0,0" CornerRadius="5" Height="34" RenderTransformOrigin="0.506,0.385">
                                            <DockPanel Margin="0,-10,0,-11">
                                                <TextBlock Text="ESTIMATED TANK CAPACITY" FontSize="11" FontWeight="SemiBold" Foreground="#137333" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="lblCapacity" Text="0.00 KL" FontSize="16" FontWeight="Bold" Foreground="#137333" HorizontalAlignment="Right" VerticalAlignment="Center" RenderTransformOrigin="0.523,0.212"/>
                                            </DockPanel>
                                        </Border>
                                        
                                        <!-- Reinforcement -->
                                        <StackPanel Name="panelReinforcement" Margin="0,15,0,0">
                                            <TextBlock Text="REINFORCEMENT DETAILS (mm)" Style="{StaticResource SectionTitle}"/>
                                            
                                            <!-- Wall -->
                                            <Border BorderBrush="#f0f0f0" BorderThickness="1" Padding="10" Margin="0,0,0,10" Background="#fcfcfc">
                                                <StackPanel>
                                                    <TextBlock Text="Wall Reinforcement" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                                    <UniformGrid Columns="2">
                                                        <StackPanel Margin="0,0,5,5">
                                                            <TextBlock Text="H. Bar Dia" FontSize="9"/>
                                                            <ComboBox x:Name="cbWallHBarDia" SelectedIndex="2">
                                                                <ComboBoxItem Content="8"/><ComboBoxItem Content="10"/><ComboBoxItem Content="12"/><ComboBoxItem Content="16"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,0,5">
                                                            <TextBlock Text="H. Spacing" FontSize="9"/>
                                                            <TextBox x:Name="txtWallHSpacing" Text="150" Padding="3"/>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,5,0">
                                                            <TextBlock Text="V. Bar Dia" FontSize="9"/>
                                                            <ComboBox x:Name="cbWallVBarDia" SelectedIndex="1">
                                                                <ComboBoxItem Content="8"/><ComboBoxItem Content="10"/><ComboBoxItem Content="12"/><ComboBoxItem Content="16"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Text="V. Spacing" FontSize="9"/>
                                                            <TextBox x:Name="txtWallVSpacing" Text="150" Padding="3"/>
                                                        </StackPanel>
                                                    </UniformGrid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Slab -->
                                            <Border BorderBrush="#f0f0f0" BorderThickness="1" Padding="10" Background="#fcfcfc">
                                                <StackPanel>
                                                    <TextBlock Text="Slab Reinforcement" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                                    <UniformGrid Columns="2">
                                                        <StackPanel Margin="0,0,5,5">
                                                            <TextBlock Text="Main Bar Dia" FontSize="9"/>
                                                            <ComboBox x:Name="cbSlabMainBarDia" SelectedIndex="2">
                                                                <ComboBoxItem Content="8"/><ComboBoxItem Content="10"/><ComboBoxItem Content="12"/><ComboBoxItem Content="16"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,0,5">
                                                            <TextBlock Text="Main Spacing" FontSize="9"/>
                                                            <TextBox x:Name="txtSlabMainSpacing" Text="150" Padding="3"/>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,5,0">
                                                            <TextBlock Text="Dist. Bar Dia" FontSize="9"/>
                                                            <ComboBox x:Name="cbSlabDistBarDia" SelectedIndex="0">
                                                                <ComboBoxItem Content="8"/><ComboBoxItem Content="10"/><ComboBoxItem Content="12"/><ComboBoxItem Content="16"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Text="Dist. Spacing" FontSize="9"/>
                                                            <TextBox x:Name="txtSlabDistSpacing" Text="150" Padding="3"/>
                                                        </StackPanel>
                                                    </UniformGrid>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel Margin="0,10,0,0">
                                                <TextBlock Text="Clear Cover (mm)" FontSize="9"/>
                                                <TextBox Name="txtClearCover" Text="40" Padding="3" Width="60" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- UPDATE DRAWING TAB -->
            <TabItem Header="Update Drawing" Margin="0,6,0,0">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="DRAWING PRODUCTION" Style="{StaticResource SectionTitle}"/>
                        <UniformGrid Columns="2" Margin="0,5,0,10">
                            <Button x:Name="btnCreateDrawings" Style="{StaticResource ActionButtonStyle}" Click="btnCreateDrawings_Click" IsEnabled="False" Height="40" Margin="0,0,5,0">
                                <TextBlock Text="Update Revit Sheet" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Name="btnExportPDF" Style="{StaticResource ActionButtonStyle}" Click="btnExportPDF_Click" IsEnabled="False" Height="40" Margin="5,0,0,0" Background="#E74C3C">
                                <TextBlock Text="Export to PDF" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>
                        </UniformGrid>
                    </StackPanel>

                    <Border BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Background="#fcfcfc" CornerRadius="4">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Assembly_VME;component/Apollo/Assets/tank.png" Height="80" Opacity="0.1" Margin="0,0,0,15"/>
                                <TextBlock Name="previewStatus" Text="No Drawing Generated" FontSize="14" Foreground="#BDC3C7" HorizontalAlignment="Center"/>
                                <TextBlock Text="Complete Precast Tab to enable Drawing Production" FontSize="10" Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Image x:Name="imgDrawingPreview" Stretch="Uniform" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- UPDATE BOQ TAB -->
            <TabItem Header="Update BOQ" Margin="0,6,0,0">
                <DockPanel Margin="10">
                    <!-- Footer Area -->
                    <Border DockPanel.Dock="Bottom" Padding="15,10" Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="0,1,0,0">
                        <Button x:Name="btnExportBOQ" Style="{StaticResource ActionButtonStyle}" Click="btnExportBOQ_Click" IsEnabled="False" Height="40">
                            <TextBlock Text="Export BOQ to Excel" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Button>
                    </Border>

                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnUpdateBOQ" Style="{StaticResource ActionButtonStyle}" Click="btnUpdateBOQ_Click" IsEnabled="False" Height="35">
                                <TextBlock Text="Calculate BOQ Quantities" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>
                            <Button x:Name="btnShowRateSettings" Grid.Column="1" Style="{StaticResource SettingsButtonStyle}" Click="btnShowRateSettings_Click" Height="35" Width="35" ToolTip="Rate Settings">
