<Window x:Class="Assembly_VME.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Export Progress"
        Height="180" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Exporting Assemblies to PDF..." 
                   FontWeight="Bold" FontSize="14"
                   Margin="0,0,0,12"/>

        <!-- Current Assembly Name -->
        <TextBlock Grid.Row="1"
                   x:Name="AssemblyNameText"
                   Text="Starting..."
                   FontSize="11"
                   Foreground="#555"
                   Margin="0,0,0,8"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="2"
                     x:Name="ExportProgressBar"
                     Height="22"
                     Minimum="0" Maximum="100"
                     Value="0"
                     Margin="0,0,0,8"/>

        <!-- Percentage + Count -->
        <TextBlock Grid.Row="3"
                   x:Name="ProgressText"
                   Text="0 of 0 (0%)"
                   FontSize="11"
                   HorizontalAlignment="Right"
                   Foreground="#333"/>
    </Grid>
</Window>